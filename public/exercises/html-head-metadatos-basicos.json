{
  "id": "html-head-metadatos-basicos",
  "topic": "html",
  "type": "build",
  "title": "Head con metadatos basicos",
  "difficulty": "base",
  "estimatedMinutes": 10,
  "prompt": "Completa un documento HTML5 para una pagina titulada \"Guia HTML\". Debe declarar idioma espanol, configurar codificacion UTF-8, viewport responsive, descripcion, autor, favicon y hoja de estilos externa.",
  "starterCode": {
    "html": "<!DOCTYPE html>\n<html>\n<head>\n  <!-- Completa el head -->\n</head>\n<body>\n  <h1>Guia HTML</h1>\n</body>\n</html>",
    "css": "",
    "javascript": ""
  },
  "validation": {
    "mode": "all",
    "successMessage": "Documento HTML5 con head completo.",
    "rules": [
      {
        "type": "regex",
        "field": "html",
        "pattern": "<!doctype\\s+html>",
        "flags": "i",
        "message": "Revisa la declaracion inicial del documento."
      },
      {
        "type": "domSelector",
        "selector": "html[lang='es']",
        "message": "Revisa el idioma del documento."
      },
      {
        "type": "domSelector",
        "selector": "head meta[charset]",
        "message": "Revisa la codificacion del documento."
      },
      {
        "type": "domSelector",
        "selector": "head title",
        "message": "Revisa el titulo del documento."
      },
      {
        "type": "domSelector",
        "selector": "head meta[name='viewport'][content*='width=device-width']",
        "message": "Revisa la configuracion responsive."
      },
      {
        "type": "domSelector",
        "selector": "head meta[name='description'][content]",
        "message": "Revisa los metadatos descriptivos."
      },
      {
        "type": "domSelector",
        "selector": "head meta[name='author'][content]",
        "message": "Revisa la autoria del documento."
      },
      {
        "type": "domSelector",
        "selector": "head link[rel='icon'][href]",
        "message": "Revisa los recursos enlazados del head."
      },
      {
        "type": "domSelector",
        "selector": "head link[rel='stylesheet'][href]",
        "message": "Revisa la hoja de estilos enlazada."
      }
    ]
  }
}
